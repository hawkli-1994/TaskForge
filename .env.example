# PostgreSQL connection used by API and Worker containers
DATABASE_URL=postgresql://taskforge:taskforge@postgres:5432/taskforge

# Redis connection used by API and Worker containers
REDIS_URL=redis://redis:6379/0

# Set to true to run API without Redis/BullMQ (dev/testing only)
TASKFORGE_DISABLE_BULLMQ=false

# Web -> API URL inside Docker network
TASKFORGE_API_URL=http://api:3001

# Set to true when serving the app over HTTPS so the auth cookie is marked Secure.
# For plain-HTTP deployments (including the default Docker Compose setup) leave it unset/false.
COOKIE_SECURE=false

# Browser origin allowed by the API CORS policy. Required when the web UI is served
# from a different host/port than the API (e.g. http://172.18.5.179:4000).
CORS_ORIGIN=http://172.18.5.179:4000

# Host ports exposed by Docker Compose.
API_PORT=4001
WEB_PORT=4000

# GitLab integration (optional)
GITLAB_API_TOKEN=
GITLAB_BASE_URL=http://172.18.5.179:8180

# GitHub integration (optional, used by pi-agent to resolve PRs)
GITHUB_TOKEN=

# LLM configuration for pi-agent PR detection (optional)
# LLM_PROVIDER=openai
# LLM_API_KEY=sk-...
# LLM_MODEL=gpt-4o-mini
# LLM_BASE_URL=
