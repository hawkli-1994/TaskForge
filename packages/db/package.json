{
  "name": "@taskforge/db",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "generate": "prisma generate --schema=prisma/sqlite/schema.prisma",
    "generate:postgres": "prisma generate --schema=prisma/postgres/schema.prisma",
    "migrate:dev": "prisma migrate dev --schema=prisma/sqlite/schema.prisma",
    "migrate:deploy": "prisma migrate deploy --schema=prisma/sqlite/schema.prisma",
    "migrate:deploy:postgres": "prisma migrate deploy --schema=prisma/postgres/schema.prisma",
    "seed": "tsx src/seed.ts",
    "validate": "DATABASE_URL='file:./dev.db' prisma validate --schema=prisma/sqlite/schema.prisma && DATABASE_URL='postgresql://localhost:5432/taskforge' prisma validate --schema=prisma/postgres/schema.prisma",
    "test": "echo 'db smoke tests run via apps/api integration tests'",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/client": "^6.6.0"
  },
  "devDependencies": {
    "prisma": "^6.6.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.3"
  }
}
