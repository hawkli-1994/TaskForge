{
  "name": "taskforge",
  "version": "0.1.0",
  "private": true,
  "description": "TaskForge v0.1 - database-driven engineering task execution control plane",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:integration": "turbo run test:integration",
    "db:generate": "pnpm --filter @taskforge/db generate",
    "db:migrate:dev": "pnpm --filter @taskforge/db migrate:dev",
    "db:seed": "pnpm --filter @taskforge/db seed",
    "db:validate": "pnpm --filter @taskforge/db validate",
    "db:test": "pnpm --filter @taskforge/db test",
    "cargo:test": "cargo test --workspace",
    "cargo:fmt": "cargo fmt --all -- --check",
    "cargo:clippy": "cargo clippy --workspace --all-targets -- -D warnings",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "turbo": "^2.5.2",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.11.0",
  "pnpm": {
    "onlyBuiltDependencies": ["@prisma/client", "@prisma/engines", "prisma", "esbuild", "msgpackr-extract"]
  }
}
